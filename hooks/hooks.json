{
  "description": "skill-concierge — semantic skill-first enforcer + invocation ledger. UserPromptSubmit: inject semantic top-k skill candidates (enforcer) and log turns/manual use (ledger). PostToolUse: log Claude's auto skill / semantic-search invocations. Fail-silent, additive-only.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/enforcer.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ledger.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill|mcp__skill-search__search_skills",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ledger.py\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
