{
  "mcpServers": {
    "skill-search": {
      "command": "${CLAUDE_PLUGIN_ROOT}/bin/skill-search-mcp",
      "env": {
        "SKILL_QDRANT_URL": "http://localhost:6333",
        "SKILL_EMBED_BACKEND": "fastembed",
        "SKILL_EMBED_MODEL": "sentence-transformers/paraphrase-multilingual-mpnet-base-v2",
        "SKILL_TOP_K": "10"
      }
    }
  }
}
