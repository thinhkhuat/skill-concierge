# telemetry output — compounding runtime data, handled by logman, never committed
logs/
# H1 rationalization harvest sink — verbatim (scrubbed) false-skip SKIPPING clauses, local-only,
# NEVER committed (may quote task text); default under logs/ but pinned explicitly too (ADR-0021)
logs/skill-rationalizations*.txt

# python
__pycache__/
*.pyc

# vendored engine: plugin-local venv + downloaded model cache (reproduced by setup, not committed)
vendor/.venv/
vendor/**/*.egg-info/
# pip build artifact left by `pip install vendor/skill-search` in setup.sh
vendor/**/build/

# os
.DS_Store

# IJFW tool state — internal session tracking (journals, transcripts, metrics, db); not part of the plugin
.ijfw/
ijfw/

# session handoff notes — scratch, not source (see CLAUDE.md)
.handoff/

# generated enrichment artifacts (rebuilt by build_triggers.py / calibrate_thresholds.py)
eval/triggers.json
eval/thresholds.json

# python test cache + local env / secrets
.pytest_cache/
.env

# local Claude Code project state — shared plugin config lives in .claude-plugin/, not here
.claude/

